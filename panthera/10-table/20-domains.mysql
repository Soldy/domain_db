
/**
 * @ptable domains
 * @pcol {uint64_t} top
 * @pcol {uint64_t} second
 * @pcol {uint64_t} sub
**/

CREATE TABLE `domains` (
    `id`     SERIAL,
    `top`    BIGINT UNSIGNED NOT NULL,
    `second` BIGINT UNSIGNED NOT NULL,
    `sub`    BIGINT UNSIGNED DEFAULT NULL,
     KEY `index` (`id`)
)  ENGINE=InnoDB DEFAULT CHARSET=utf8 COLLATE=utf8_unicode_ci;
