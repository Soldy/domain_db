
/**
 * @pfunction domainSplitSecond
 * @pparam {string} IDOMAIN
 * @preturn {string}
**/

CREATE OR REPLACE FUNCTION `domainSplitSecond`(
    IDOMAIN VARCHAR(256)
      CHARACTER SET utf8
      COLLATE utf8_unicode_ci
) RETURNS VARCHAR(256)
      CHARACTER SET utf8
      COLLATE utf8_unicode_ci
BEGIN
    RETURN (
        SELECT
            SUBSTRING_INDEX(
                SUBSTRING_INDEX(
                    LOWER(IDOMAIN), '.', -2
                ),'.', 1
            )
    );
END;
